{
	"name": "threlte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:netlify": "cross-env BUILD_TARGET=netlify vite build",
		"build:itch": "cross-env BUILD_TARGET=itch vite build && node scripts/fix-itch-paths.mjs",
		"test:itch": "node scripts/test-itch-build.mjs",
		"test:itch:runtime": "node scripts/test-itch-runtime.mjs",
		"zip:itch": "node scripts/zip-itch.mjs",
		"itch": "npm run build:itch && npm run test:itch && npm run test:itch:runtime && npm run zip:itch",
		"deploy": "npm run build:itch && npm run test:itch && npm run test:itch:runtime && butler push build/ pndgames/snowmanrun:web",
		"deploy:status": "butler status pndgames/snowmanrun:web",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.39.1",
		"@sveltejs/adapter-static": "^3.0.9",
		"@sveltejs/adapter-netlify": "^5.2.4",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.0.15",
		"archiver": "^7.0.1",
		"cross-env": "^7.0.3",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^16.5.0",
		"playwright": "^1.57.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"vite": "^7.2.6",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.15",
		"vitest-browser-svelte": "^2.0.1"
	},
	"dependencies": {
		"@threlte/core": "^8.3.1",
		"@threlte/extras": "^9.7.1",
		"three": "^0.182.0"
	}
}